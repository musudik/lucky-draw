# PostgreSQL credentials ─ copy this file to .env and fill in real values.
# The deploy.sh script will create .env automatically if it does not exist.

# Database name
DB_NAME=luckydb

# Database superuser (used by the app)
DB_USER=luckyadmin

# Strong password — change before first run
DB_PASSWORD=CHANGE_ME_strong_password_here

# (optional) External port bound to 127.0.0.1.  Default: 5432.
# Change only if another service already listens on 5432.
DB_PORT=5432

# Backup directory on the VPS host (created automatically by deploy.sh)
BACKUP_DIR=/opt/lucky-draw/backups
