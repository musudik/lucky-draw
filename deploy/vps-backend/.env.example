# ── Database ──────────────────────────────────────────────────────────────────
# If PostgreSQL is running on the same VPS (via deploy/vps-db/deploy.sh),
# use 127.0.0.1 here — never expose port 5432 to the internet.
DATABASE_URL=postgresql://luckyadmin:CHANGE_ME@127.0.0.1:5432/luckydb

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_long_random_secret

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=4000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash).
# This controls which origins can call the API and connect via Socket.io.
FRONTEND_URL=https://your-app.vercel.app

# ── NGINX / HTTPS (optional) ──────────────────────────────────────────────────
# If set, deploy-backend.sh will configure NGINX + request a Let's Encrypt cert.
# The domain must already point to this VPS in your DNS before running the script.
BACKEND_DOMAIN=api.yourdomain.com

# Email used by Certbot for TLS certificate renewal notices.
CERTBOT_EMAIL=you@yourdomain.com
